{
  "name": "reevesagents",
  "version": "0.9.0",
  "description": "Compose and run AI CLI trees in tmux",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "bin": {
    "reevesagents": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "react": "^19.2.6",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "latest",
    "ink-testing-library": "^4.0.0",
    "prettier": "latest",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.19"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mertkayacs/reevesagents.git"
  },
  "bugs": {
    "url": "https://github.com/mertkayacs/reevesagents/issues"
  },
  "homepage": "https://github.com/mertkayacs/reevesagents#readme",
  "keywords": [
    "ai",
    "claude",
    "codex",
    "gemini",
    "tmux",
    "orchestrator",
    "cli",
    "ink"
  ]
}
